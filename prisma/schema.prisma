// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Asset {
  id         String   @id @default(cuid())
  userId     String
  campaignId String
  imageUrl   String
  name       String
  createdAt  DateTime @default(now())
}