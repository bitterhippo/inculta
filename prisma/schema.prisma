// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url = env(NEXT_PUBLIC_DATABASE_URL)
}

model Asset {
  id         String   @id @default(cuid())
  userId     String
  campaignId String
  imageUrl   String
  name       String
  createdAt  DateTime @default(now())
}